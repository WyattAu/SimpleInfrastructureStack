# Path: /monitoring/.env
# ===================================================================
# MONITORING STACK ENVIRONMENT
# ===================================================================

# --- Service Versions (Pinned) ---
PROMETHEUS_VERSION=v2.54.1
GRAFANA_VERSION=11.3.0
LOKI_VERSION=2.9.8
PROMTAIL_VERSION=2.9.8
KUMA_VERSION=1.23.13
CADVISOR_VERSION=v0.49.1
NODE_EXPORTER_VERSION=v1.8.2

# --- Subdomains ---
PROMETHEUS_SUBDOMAIN="prometheus"
GRAFANA_SUBDOMAIN="grafana"
KUMA_SUBDOMAIN="kuma"

# --- Grafana Credentials ---
# Admin password for the local Grafana user account.
# Primary authentication is handled via Keycloak OIDC.
GRAFANA_ADMIN_PASSWORD="GENERATE_THIS"

# --- Grafana Keycloak OIDC Client Credentials ---
GRAFANA_OIDC_CLIENT_ID="grafana"
GRAFANA_OIDC_CLIENT_SECRET="GET_FROM_KEYCLOAK"
