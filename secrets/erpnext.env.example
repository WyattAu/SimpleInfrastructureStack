# ERPNext Stack Secrets
# Copy to erpnext.env, fill in real values, then encrypt:
#   sops --encrypt --input-type dotenv --output-type dotenv \
#     --config .sops.yaml --output secrets/erpnext.env.encrypted secrets/erpnext.env
# Then delete the plaintext erpnext.env.

# MariaDB root password (used by MariaDB + configurator bench new-site)
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ERPNext admin password (bench new-site --admin-password)
ERPNEXT_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
