# Secrets (NEVER commit these)
*.env
!*.env.example
!*.env.encrypted
*.pem
*.key
*.crt

# SOPS metadata (only contains public keys — safe to commit)
# .sops.yaml is NOT ignored; it contains only age public key references

# Age keys
*.age
age-keygen*

# Ansible
*.retry
*.log

# Webhook (generated from template at runtime)
stacks/webhook/hooks.yaml

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
*.swp
*.swo
*~

# Terraform
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Temporary files
/tmp/
*.tmp
