# ===================================================================
# SimpleInfrastructureStack .gitignore
# ===================================================================

# --- Secrets & Environment Files ---
*.env
!.env.example

# --- OS Files ---
.DS_Store
Thumbs.db

# --- Editor Files ---
*.swp
*.swo
*~
.idea/
*.sublime-project
*.sublime-workspace

# --- Docker ---
.docker/

# --- VS Code ---
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# --- Local History ---
.history/
.localhistory/

# --- Logs ---
*.log

# --- Backup files ---
*~
*.bak
*.tmp
