# --- Service Versions (Pinned) ---
TRAEFIK_VERSION=v3.0.0
SOCKET_PROXY_VERSION=1.14.2
CF_DDNS_VERSION=2.1.3
OAUTH2_PROXY_VERSION=v7.12.0
NGINX_VERSION=1.25.4-alpine

# --- Forward Auth Secret ---
