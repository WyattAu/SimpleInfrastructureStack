# Matrix Hookshot configuration
# See: https://matrix-org.github.io/matrix-hookshot/setup/github.html

bridge:
  domain: wyattau.com
  url: http://collaboration-synapse:8008
  mediaUrl: https://matrix.wyattau.com

# In v7.3.2, listeners handle ALL HTTP including appservice API.
# Do NOT set bridge.port — it causes EADDRINUSE conflict with listeners.
listeners:
  - port: 8080
    bindAddress: 0.0.0.0
    resources:
      - webhooks

permissions:
  - actor: wyattau.com
    services:
      - service: "*"
        level: admin

github:
  auth:
    id: {{ GITHUB_APP_ID }}
    privateKeyFile: /data/github-app-private-key.pem
  webhook:
    secret: {{ GITHUB_WEBHOOK_SECRET }}
  allowWebhooks: true
  webhookNotifications:
    enabled: true

passfile: /data/registration.yml
passkeyPath: /data/passkey.pem

logging:
  level: info
  colorize: false
  json: false
  timestampFormat: "YYYY-MM-DD HH:mm:ss"
