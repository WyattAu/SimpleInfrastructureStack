{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Event Processing Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "synapse_event_processing_lag_seconds",
          "legendFormat": "lag"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0, "color": { "fixedColor": "orange", "mode": "fixed" } },
        "overrides": []
      },
      "alert": {
        "name": "Event Processing Lag Alert",
        "conditions": [{ "evaluator": { "params": [60], "type": "gt" }, "operator": { "type": "and" }, "query": { "params": ["A", "5m", "now"] }, "reducer": { "params": [], "type": "avg" }, "type": "query" }]
      }
    },
    {
      "title": "Events Processed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(synapse_event_processing_time_sum[5m]) / rate(synapse_event_processing_time_count[5m])",
          "legendFormat": "avg processing time"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0, "color": { "fixedColor": "blue", "mode": "fixed" } },
        "overrides": []
      }
    },
    {
      "title": "Active Users (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "synapse_active_users_total",
          "legendFormat": "users"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [] } },
        "overrides": []
      }
    },
    {
      "title": "Total Rooms",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "synapse_rooms_total",
          "legendFormat": "rooms"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [] } },
        "overrides": []
      }
    },
    {
      "title": "Memory Usage",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"synapse\"}",
          "legendFormat": "RSS"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "min": 0, "max": 8589934592, "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 6442450944 },
          { "color": "red", "value": 7730941132 }
        ] } },
        "overrides": []
      }
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{job=\"synapse\"}",
          "legendFormat": "uptime"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [] } },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["infrastructure", "synapse", "matrix"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Synapse (Matrix)",
  "uid": "synapse-matrix"
}
