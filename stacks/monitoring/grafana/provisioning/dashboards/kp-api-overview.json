{
  "title": "Kingston Peptides — API",
  "uid": "kp-api-overview",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["kingston-peptides", "production"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "15s",
  "templating": { "list": [] },
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "sum(rate(kp_http_requests_total{job=\"kp-api\"}[5m])) by (path)",
        "legendFormat": "{{path}}",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Error Rate (%)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "sum(rate(kp_http_requests_total{job=\"kp-api\",status=~\"5..\"}[5m])) / sum(rate(kp_http_requests_total{job=\"kp-api\"}[5m])) * 100",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "In-Flight Requests",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "kp_http_requests_in_flight{job=\"kp-api\"}",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Request Duration (p50, p95, p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(kp_http_request_duration_seconds_bucket{job=\"kp-api\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(kp_http_request_duration_seconds_bucket{job=\"kp-api\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(kp_http_request_duration_seconds_bucket{job=\"kp-api\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Orders Created (rate/hour)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": { "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "sum(rate(kp_orders_created_total{job=\"kp-api\"}[1h])) by (payment_method) * 3600",
        "legendFormat": "{{payment_method}}",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Total Revenue (£)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": { "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "sum(kp_orders_value_total_gbp{job=\"kp-api\"})",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "currencyGBP" } }
    },
    {
      "title": "Orders by Status",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "kp_orders_by_status{job=\"kp-api\"}",
        "legendFormat": "{{status}}",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Process Memory (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "process_resident_memory_bytes{job=\"kp-api\"} / 1048576",
        "legendFormat": "RSS",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "MB" } }
    },
    {
      "title": "CPU Usage (%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "rate(process_cpu_seconds_total{job=\"kp-api\"}[5m]) * 100",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      }
    }
  ]
}
