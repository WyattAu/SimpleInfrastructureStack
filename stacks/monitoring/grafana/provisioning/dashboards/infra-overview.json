{
  "title": "Infrastructure Overview",
  "uid": "infra-overview",
  "version": 1,
  "schemaVersion": 39,
  "tags": [
    "overview"
  ],
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Services Up",
      "type": "stat",
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "count(up == 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red"
              },
              {
                "color": "green",
                "value": 40
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal"
      }
    },
    {
      "id": 2,
      "title": "Services Down",
      "type": "stat",
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "count(up == 0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal"
      }
    },
    {
      "id": 3,
      "title": "CPU %",
      "type": "gauge",
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "100 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m]) * 100)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "Memory %",
      "type": "gauge",
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "Network RX",
      "type": "timeseries",
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\"}[5m])",
          "refId": "A",
          "legendFormat": "{{instance}} {{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Network TX",
      "type": "timeseries",
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\"}[5m])",
          "refId": "A",
          "legendFormat": "{{instance}} {{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Container CPU Top10",
      "type": "timeseries",
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "topk(10, rate(container_cpu_usage_seconds_total{name!=\"\"}[5m]) * 100)",
          "refId": "A",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "Container Mem Top10",
      "type": "timeseries",
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "expr": "topk(10, container_memory_usage_bytes{name!=\"\"})",
          "refId": "A",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "title": "Disk Read",
      "type": "timeseries",
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total[5m])",
          "refId": "A",
          "legendFormat": "{{instance}} {{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "title": "Disk Write",
      "type": "timeseries",
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "targets": [
        {
          "expr": "rate(node_disk_written_bytes_total[5m])",
          "refId": "A",
          "legendFormat": "{{instance}} {{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      }
    }
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "10s",
  "annotations": {
    "list": []
  }
}