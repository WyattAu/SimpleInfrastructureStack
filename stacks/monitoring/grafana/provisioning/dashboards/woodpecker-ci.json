{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Connected Workers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "woodpecker_worker_count",
          "legendFormat": "workers"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "title": "Pending Steps",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "woodpecker_pending_steps",
          "legendFormat": "pending"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "title": "Running Steps",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "woodpecker_running_steps",
          "legendFormat": "running"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [] }, "noValue": "0" },
        "overrides": []
      }
    },
    {
      "title": "Waiting Steps",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "woodpecker_waiting_steps",
          "legendFormat": "waiting"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [] }, "noValue": "0" },
        "overrides": []
      }
    },
    {
      "title": "Pipeline Build Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "woodpecker_pipeline_time{branch=\"main\"}",
          "legendFormat": "{{repo}} ({{status}})"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0, "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "title": "Total Pipelines",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "woodpecker_pipeline_total_count",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [] } },
        "overrides": []
      }
    },
    {
      "title": "Total Users",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "woodpecker_user_count",
          "legendFormat": "users"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [] } },
        "overrides": []
      }
    },
    {
      "title": "Total Repos",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "woodpecker_repo_count",
          "legendFormat": "repos"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [] } },
        "overrides": []
      }
    },
    {
      "title": "Server Memory",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"woodpecker\"}",
          "legendFormat": "RSS"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "thresholds": { "mode": "absolute", "steps": [] } },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["infrastructure", "woodpecker", "ci"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Woodpecker CI",
  "uid": "woodpecker-ci"
}
