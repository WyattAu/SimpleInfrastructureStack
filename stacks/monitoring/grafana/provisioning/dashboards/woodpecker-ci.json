{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Server Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "up{job=\"woodpecker\"}",
          "legendFormat": "status"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [] },
          "noValue": "N/A"
        },
        "overrides": []
      }
    },
    {
      "title": "Goroutines",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "go_goroutines{job=\"woodpecker\"}",
          "legendFormat": "goroutines"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [] } },
        "overrides": []
      }
    },
    {
      "title": "Go Version",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "go_info{job=\"woodpecker\"}",
          "legendFormat": "version",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [] } },
        "overrides": []
      }
    },
    {
      "title": "Memory (Alloc)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "go_memstats_alloc_bytes{job=\"woodpecker\"}",
          "legendFormat": "alloc"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "thresholds": { "mode": "absolute", "steps": [] } },
        "overrides": []
      }
    },
    {
      "title": "Heap Allocation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "go_memstats_alloc_bytes{job=\"woodpecker\"}",
          "legendFormat": "allocated"
        },
        {
          "expr": "go_memstats_heap_inuse_bytes{job=\"woodpecker\"}",
          "legendFormat": "heap in-use"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "min": 0, "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "title": "GC Pause Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(go_gc_duration_seconds_sum{job=\"woodpecker\"}[5m]) / rate(go_gc_duration_seconds_count{job=\"woodpecker\"}[5m])",
          "legendFormat": "avg GC pause"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0, "color": { "fixedColor": "orange", "mode": "fixed" } },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["infrastructure", "woodpecker", "ci"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Woodpecker CI",
  "uid": "woodpecker-ci",
  "description": "Woodpecker CI server runtime metrics. Note: Woodpecker v4 does not expose application-level metrics (pipelines, repos, users). The primary value is verifying the server is UP via Prometheus target monitoring."
}
