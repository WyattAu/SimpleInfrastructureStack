{
  "annotations": {"list": []},
  "title": "Forgejo CI",
  "uid": "forgejo-ci",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["infrastructure", "ci"],
  "time": {"from": "now-6h", "to": "now"},
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Forgejo Status",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "up{job=\"forgejo\"}", "legendFormat": "Status"}],
      "fieldConfig": {"defaults": {"mappings": [{"options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}], "type": "value"}]}
    },
    {
      "id": 2,
      "title": "Repositories",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "gitea_repositories", "legendFormat": "Repos"}]
    },
    {
      "id": 3,
      "title": "Organizations",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "gitea_organizations", "legendFormat": "Orgs"}]
    },
    {
      "id": 4,
      "title": "Open Issues",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "gitea_issues_open", "legendFormat": "Open"}]
    },
    {
      "id": 5,
      "title": "Forgejo Request Rate (req/s)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{"expr": "rate(gitea_http_requests_total[5m])", "legendFormat": "{{status}}"}]
    },
    {
      "id": 6,
      "title": "Forgejo Response Duration (p99)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{"expr": "histogram_quantile(0.99, rate(gitea_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p99"}]
    },
    {
      "id": 7,
      "title": "CI Runners (on CachyOS)",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "targets": [{"expr": "up{job=~\"cachyos.*\"}", "format": "table", "instant": true}]
    },
    {
      "id": 8,
      "title": "Forgejo Memory Usage",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [{"expr": "container_memory_usage_bytes{name=\"operations-forgejo\"}", "legendFormat": "RSS"}]
    },
    {
      "id": 9,
      "title": "Forgejo CPU Usage",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [{"expr": "rate(container_cpu_usage_seconds_total{name=\"operations-forgejo\"}[5m]) * 100", "legendFormat": "CPU%"}]
    }
  ]
}
