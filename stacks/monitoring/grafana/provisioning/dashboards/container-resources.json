    {
      "title": "CPU Usage by Container",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\".+\"}[5m]) * 100",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "title": "Memory Usage by Container",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\".+\"}",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "title": "Network I/O by Container",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{name=~\".+\"}[5m])",
          "legendFormat": "{{name}} rx"
        },
        {
          "expr": "rate(container_network_transmit_bytes_total{name=~\".+\"}[5m])",
          "legendFormat": "{{name}} tx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "title": "Container Restarts",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "count by (container_label_com_docker_compose_service, container_label_restartcount) (container_last_seen{container_label_restartcount!=\"\"})",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 5 },
                    { "color": "red", "value": 20 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "container_label_com_docker_compose_service"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 200
              },
              {
                "id": "displayName",
                "value": "Service"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "container_label_restartcount"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Restarts"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true
            },
            "indexByName": {
              "container_label_com_docker_compose_service": 0,
              "container_label_restartcount": 1
            },
            "renameByName": {}
          }
        }
      ]
    }
