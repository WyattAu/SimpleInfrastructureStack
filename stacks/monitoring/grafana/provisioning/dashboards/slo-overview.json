          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "(1 - slo:availability_ratio:30d{job=\"traefik\"}) < 0.001 * 2592000 or vector(0)",
