    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Remaining error budget as a percentage. 100% = full budget remaining, 0% = budget exhausted.\n\nCritical services (Traefik, Keycloak): 0.1% budget = 43.2 min/month\nImportant services (Forgejo, Grafana, Loki, Synapse): 0.5% budget = 3.6 hours/month",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "yellow", "value": 30 },
              { "color": "green", "value": 50 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
      "id": 11,
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "text": { "valueSize": 14 }
      },
      "pluginVersion": "11.5.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "(slo:availability_ratio:30d{job=\"traefik\"} - 0.999) / 0.001 * 100",
          "legendFormat": "Traefik",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "(slo:availability_ratio:30d{job=\"keycloak\"} - 0.999) / 0.001 * 100",
