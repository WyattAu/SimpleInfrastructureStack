            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "(slo:availability_ratio:30d{job=\"forgejo\"} - 0.995) / 0.005 * 100",
          "legendFormat": "Forgejo",
          "range": true,
          "refId": "C"
        },
