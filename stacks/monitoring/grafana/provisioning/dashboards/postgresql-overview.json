      "title": "Connections per Instance",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "pg_stat_activity_count{datname!~\"template.*\"}",
          "legendFormat": "{{datname}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "min": 0
