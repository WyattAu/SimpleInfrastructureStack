{
  "title": "OCIS Storage",
  "uid": "ocis-storage",
  "version": 1,
  "schemaVersion": 39,
  "tags": [
    "storage",
    "ocis"
  ],
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "OCIS Status",
      "type": "stat",
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "up{job=\"ocis\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal"
      }
    },
    {
      "id": 2,
      "title": "Request Rate",
      "type": "timeseries",
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"ocis\"}[5m])",
          "refId": "A",
          "legendFormat": "{{method}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Duration p95",
      "type": "timeseries",
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"ocis\"}[5m])) by (le))",
          "refId": "A",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Goroutines",
      "type": "timeseries",
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "go_goroutines{job=\"ocis\"}",
          "refId": "A",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Memory",
      "type": "timeseries",
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "expr": "go_memstats_alloc_bytes{job=\"ocis\"}",
          "refId": "A",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    }
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "annotations": {
    "list": []
  }
}