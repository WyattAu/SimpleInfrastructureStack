{
  "annotations": {"list": []},
  "title": "Minecraft Server",
  "uid": "minecraft",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["personal", "gaming"],
  "time": {"from": "now-6h", "to": "now"},
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Java Server (25565)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "probe_success{job=\"blackbox-mc-java\"}", "legendFormat": "Java"}],
      "fieldConfig": {"defaults": {"mappings": [{"options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}], "type": "value"}}
    },
    {
      "id": 2,
      "title": "Bedrock Server (19132)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "probe_success{job=\"blackbox-mc-bedrock\"}", "legendFormat": "Bedrock"}],
      "fieldConfig": {"defaults": {"mappings": [{"options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}], "type": "value"}}
    },
    {
      "id": 3,
      "title": "Connection Latency",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"expr": "probe_duration_seconds{job=\"blackbox-mc-java\"}", "legendFormat": "Java"},
        {"expr": "probe_duration_seconds{job=\"blackbox-mc-bedrock\"}", "legendFormat": "Bedrock"}
      ]
    },
    {
      "id": 4,
      "title": "CachyOS Host Memory",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{
        "expr": "(1 - (node_memory_MemAvailable_bytes{instance=\"192.168.1.191:9100\"} / node_memory_MemTotal_bytes{instance=\"192.168.1.191:9100\"})) * 100",
        "legendFormat": "Memory %"
      }],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "thresholds": {"steps": [{"color": "green"}, {"color": "yellow", "value": 80}, {"color": "red", "value": 90}]}}}
    },
    {
      "id": 5,
      "title": "CachyOS Host CPU",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{
        "expr": "100 - (avg(rate(node_cpu_seconds_total{instance=\"192.168.1.191:9100\",mode=\"idle\"}[5m])) * 100)",
        "legendFormat": "CPU %"
      }]
    }
  ]
}
