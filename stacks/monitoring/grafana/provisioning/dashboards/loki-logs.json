{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Ingestion Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(loki_ingester_lines_received_total[5m]))",
          "legendFormat": "lines/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "lines/s", "min": 0, "color": { "fixedColor": "blue", "mode": "fixed" } },
        "overrides": []
      }
    },
    {
      "title": "Query Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(loki_query_scheduler_queries_total[5m]))",
          "legendFormat": "queries/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0, "color": { "fixedColor": "green", "mode": "fixed" } },
        "overrides": []
      }
    },
    {
      "title": "Request Errors (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(loki_request_duration_seconds_count{status_code=~\"5..\"}[5m])) by (method, path)",
          "legendFormat": "{{method}} {{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0, "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"loki\"}",
          "legendFormat": "RSS"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "min": 0, "color": { "fixedColor": "purple", "mode": "fixed" } },
        "overrides": []
      }
    },
    {
      "title": "Chunk Store",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "loki_storage_chunks_total",
          "legendFormat": "chunks"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [] } },
        "overrides": []
      }
    },
    {
      "title": "TSDB Rows",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "loki_tsdb_index_rows_total",
          "legendFormat": "rows"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [] } },
        "overrides": []
      }
    },
    {
      "title": "Goroutines",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "go_goroutines{job=\"loki\"}",
          "legendFormat": "goroutines"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [] } },
        "overrides": []
      }
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{job=\"loki\"}",
          "legendFormat": "uptime"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [] } },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["infrastructure", "loki", "logs"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Loki Logs",
  "uid": "loki-logs"
}
