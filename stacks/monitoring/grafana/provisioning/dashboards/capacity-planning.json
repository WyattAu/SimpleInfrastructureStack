      "title": "Data Pool Total",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Estimated days until data pool is full based on 7-day growth rate.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 30 },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 180 }
            ]
          },
          "unit": "d"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "node_filesystem_avail_bytes{mountpoint=\"/mnt/pool_HDD_x2\"} / clamp_min(absent_over_time(node_filesystem_avail_bytes{mountpoint=\"/mnt/pool_HDD_x2\"}[7d:1h]) - node_filesystem_avail_bytes{mountpoint=\"/mnt/pool_HDD_x2\"}, 1) / 86400",
          "legendFormat": "Days to full",
          "refId": "A"
        }
      ],
      "title": "Days to Full (est.)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
