- id: deploy
  execute-command: /opt/webhook/deploy.sh
  trigger-rule:
    and:
      - match:
          type: payload-hmac-sha256
          secret: "${WEBHOOK_SECRET}"
          parameter:
            source: header
            name: X-Hub-Signature-256
  trigger-rule-mismatch-http-response-code: 403
  response-headers:
    - name: Content-Type
      value: application/json
  success-message: "Deploy triggered"
