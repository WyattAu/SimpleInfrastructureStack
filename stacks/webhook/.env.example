# Webhook Configuration
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=GENERATE_THIS

# GitHub repo URL (for initial clone)
REPO_URL=https://github.com/WyattAu/SimpleInfrastructureStack.git
REPO_BRANCH=main

# SOPS age key mount path (on the host)
# Create this directory and place your keys.txt inside it
# This directory is bind-mounted read-only into the container
SOPS_AGE_KEY_PATH=./age-keys
