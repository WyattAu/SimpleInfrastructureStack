# Webhook Configuration
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=GENERATE_THIS

# GitHub repo URL (for initial clone)
REPO_URL=https://github.com/WyattAu/SimpleInfrastructureStack.git
REPO_BRANCH=main

# SOPS age key directory (on the host)
# Must be the parent directory containing keys.txt
# This directory is bind-mounted read-only into the container at /root/.config/sops/age
SOPS_AGE_KEY_DIR=/root/.config/sops/age
