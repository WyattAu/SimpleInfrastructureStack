# CrowdSec Cloudflare Workers Bouncer Configuration
# ================================================
# This file is templated at deploy time by Ansible Jinja2.
# Secrets are sourced from SOPS-encrypted security.env.encrypted.
# DO NOT hardcode secrets here.

crowdsec_config:
  lapi_key: {{ CF_BOUNCER_API_KEY }}
  lapi_url: http://security-crowdsec:8080
  update_frequency: 10s
  only_include_decisions_from: ["cscli", "crowdsec"]
  # Limit to local decisions to stay within free plan KV write limits (1K/day)
  insecure_skip_verify: false

cloudflare_config:
    accounts:
        - id: "26966ba2f4b3a12cb750cd615c8d0bcf"
          zones:
            - zone_id: "{{ CF_ZONE_ID }}"
              actions:
                - ban
              default_action: ban
              routes_to_protect: []
          token: "{{ CF_API_TOKEN }}"

log_level: info
log_media: "stdout"

prometheus:
    enabled: true
    listen_addr: 0.0.0.0
    listen_port: "2112"
