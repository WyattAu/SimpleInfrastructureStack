# CrowdSec security stack
CROWDSEC_VERSION=v1.6.2
# CF Workers Bouncer binary — NOT a Docker image, version tracked in versions.env
TZ=UTC
PGID=1001
CROWDSEC_LAPI_SECRET=  # Auto-generated, stored in secrets/security.env.encrypted
CF_API_TOKEN=          # Cloudflare API token with Workers Scripts/KV/Routes Edit permission
CF_ZONE_ID=            # Cloudflare Zone ID (same as proxy CF_ZONE_ID)
CF_BOUNCER_API_KEY=    # Registered via: cscli bouncers add cloudflare-workers-bouncer -oraw
