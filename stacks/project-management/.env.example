# Taiga project management stack
DOMAIN_NAME=
DATA_BASE_PATH=

# PostgreSQL
POSTGRES_USER=taiga
POSTGRES_PASSWORD=  # Auto-generated, stored in secrets/project-management.env.encrypted

# RabbitMQ
RABBITMQ_USER=taiga
RABBITMQ_PASS=  # Auto-generated, stored in secrets/project-management.env.encrypted
RABBITMQ_ERLANG_COOKIE=  # Auto-generated, stored in secrets/project-management.env.encrypted

# Taiga
TAIGA_SECRET_KEY=  # Auto-generated, stored in secrets/project-management.env.encrypted

# Email (uses global SMTP settings)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
