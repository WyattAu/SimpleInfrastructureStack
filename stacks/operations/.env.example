# Path: /operations/.env
# ===================================================================
# OPERATIONS STACK ENVIRONMENT
# ===================================================================

# --- Subdomains ---
FORGEJO_SUBDOMAIN="forgejo"
REGISTRY_SUBDOMAIN="registry-forgejo"

# --- Forgejo Database Credentials ---
POSTGRES_DB_FORGEJO="forgejo"
POSTGRES_USER_FORGEJO="forgejo"
POSTGRES_PASSWORD_FORGEJO="GENERATE_THIS"

# --- Forgejo OIDC Client Credentials ---
FORGEJO_OIDC_CLIENT_ID="forgejo"
FORGEJO_OIDC_CLIENT_SECRET="GET_FROM_KEYCLOAK"

# --- Forgejo Runner ---
FORGEJO_RUNNER_VERSION=12.8.2
