# Vaultwarden Configuration
# Setup: https://github.com/dani-garcia/vaultwarden/wiki

# The domain must match the URL Vaultwarden is accessed from.
# Used for WebSocket connections, email links, and attachments.
VAULTWARDEN_SUBDOMAIN=vault
VAULTWARDEN_DOMAIN=https://vault.wyattau.com

# --- Security ---
# Signups are disabled by default. Create users via the admin panel
# after setting ADMIN_TOKEN below.
SIGNUPS_ALLOWED=false
SIGNUPS_VERIFY=false
# Invitations allow existing users to invite others by email.
INVITATIONS_ALLOWED=true
# Show password hints on the login page.
SHOW_PASSWORD_HINT=false

# --- Admin Panel ---
# Access at https://vault.wyattau.com/admin
# Set a strong random token. If empty, admin panel is disabled.
# Generated with: openssl rand -base64 48
ADMIN_TOKEN=GENERATE_THIS

# --- Advanced ---
# Logging level: trace, debug, info, warn, error
LOG_LEVEL=warn
# Extended logging for troubleshooting (set to true temporarily)
EXTENDED_LOGGING=false
# Disable icon downloading (reduces external requests)
ICON_SERVICE=internal
