[Unit]
Description=Purpur Minecraft Server
After=network.target

[Service]
Type=forking
User=minecraft
Group=minecraft
WorkingDirectory=/opt/minecraft
ExecStart=/usr/bin/tmux new-session -s mc-server -d /opt/minecraft/start.sh
ExecStop=/usr/bin/tmux send-keys -t mc-server stop Enter
TimeoutStopSec=60
Restart=on-failure
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
