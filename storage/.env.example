# Path: /storage/.env
# ===================================================================
# STORAGE STACK ENVIRONMENT (ownCloud Infinite Scale)
# ===================================================================

# --- Service Version (Pinned) ---
OCIS_VERSION=5.0.0

# --- Subdomain ---
OCIS_SUBDOMAIN="ocis"

# --- OCIS Configuration ---
OCIS_MACHINE_AUTH_API_KEY="GENERATE_THIS"
OCIS_SYSTEM_USER_API_KEY="GENERATE_THIS"
OCIS_ADMIN_USERNAME="ocis-admin"
OCIS_ADMIN_PASSWORD="GenerateAStrongPasswordForOCISAdmin"

# --- OCIS JWT Secret ---
# Required for the collaboration service to authenticate with the OCIS gateway.
# Generate with: openssl rand -hex 32
OCIS_JWT_SECRET="GENERATE_THIS"

# --- Collabora Version (Pinned) ---
COLLABORA_VERSION=24.04.4.3.1

# --- Keycloak OIDC Client Credentials ---
OCIS_OIDC_CLIENT_ID="ocis"
OCIS_OIDC_CLIENT_SECRET="PasteTheOCISClientSecretFromKeycloakHere"
