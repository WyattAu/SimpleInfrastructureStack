# ===================================================================
# GLOBAL ENVIRONMENT CONFIGURATION
# ===================================================================

# --- System User & Group IDs ---
PUID=1001
PGID=1001

# --- System Timezone ---
TZ="UTC"

# --- Core Host Paths ---
DATA_BASE_PATH="/mnt/mainpool/sis/appdata"
BACKUP_BASE_PATH="/mnt/mainpool/sis/backups"

# --- Domain Configuration ---
DOMAIN_NAME="yourcompany.com"
HOMEPAGE_SUBDOMAIN="homepage"

# --- Homepage Version ---
HOMEPAGE_VERSION=v1.5

# --- Let's Encrypt Email ---
LE_EMAIL="devops@yourcompany.com"

# --- Cloudflare API Credentials ---
CF_API_TOKEN="YOUR_CLOUDFLARE_API_TOKEN"
CF_ZONE_ID="YOUR_CLOUDFLARE_ZONE_ID"

# --- Backup Configuration ---
# Password for the Restic backup repository.
# Generate with: openssl rand -base64 32
RESTIC_PASSWORD="GENERATE_THIS"
