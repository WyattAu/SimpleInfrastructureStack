# Path: /collaboration/.env
# ===================================================================
# COLLABORATION STACK ENVIRONMENT (Matrix Synapse + Element Web)
# ===================================================================

# --- Service Versions (Pinned) ---
SYNAPSE_VERSION=v4.0.2
POSTGRES_VERSION=16.2-alpine
ELEMENT_VERSION=v1.13.0
HOOKSHOT_VERSION=7.1.0

# --- Subdomains ---
MATRIX_SUBDOMAIN="matrix"
ELEMENT_SUBDOMAIN="element"
HOOKSHOT_SUBDOMAIN="hookshot"

# --- Synapse Configuration ---
# The public server name for this Matrix homeserver.
# This MUST match your domain and DNS configuration.
SYNAPSE_SERVER_NAME="${DOMAIN_NAME}"

# Whether to report anonymous statistics to matrix.org.
SYNAPSE_REPORT_STATS="false"

# --- Synapse Database Credentials ---
POSTGRES_DB_SYNAPSE="synapse"
POSTGRES_USER_SYNAPSE="synapse"
POSTGRES_PASSWORD_SYNAPSE="GENERATE_THIS"

# --- Element Web Configuration ---
ELEMENT_ROOM_NAME="Company Chat"
