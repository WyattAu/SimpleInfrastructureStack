{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": ["dependencies"],
  "branchPrefix": "renovate/",
  "prHourlyLimit": 2,
  "prConcurrentLimit": 3,
  "rebaseWhen": "behind-base-branch",
  "schedule": ["every weekend"],
  "commitMessagePrefix": "deps:",
  "commitMessageAction": "update",
  "packageRules": [
    {
      "description": "Skip built-in docker-compose extraction — custom manager handles versions.env",
      "matchManagers": ["docker-compose"],
      "matchFiles": ["stacks/*/docker-compose.yml"],
      "enabled": false
    },
    {
      "description": "Auto-merge minor and patch Docker image updates after CI passes",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "automergeSchedule": ["every weekend"]
    },
    {
      "description": "Major Docker image updates require manual review",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Forgejo runner must be reviewed — version must match server",
      "matchPackageNames": ["data.forgejo.org/forgejo/runner"],
      "matchDatasources": ["docker"],
      "automerge": false
    },
    {
      "description": "Chainguard free-tier images only have :latest — pin by digest and auto-merge",
      "matchPackageNames": ["cgr.dev/chainguard/**"],
      "matchDatasources": ["docker"],
      "pinDigests": true,
      "automerge": true,
      "automergeType": "pr"
    }
  ],
  "customManagers": [
    {
      "description": "Parse Docker image versions from versions.env files",
      "customType": "regex",
      "fileMatch": ["stacks/.+/versions\\.env$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: extractVersion=(?<extractVersion>.+?))?\\n\\S+=(?<currentValue>.*)"
      ]
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true
  }
}
